#include "..\..\shared\midi_sdk_idl_defs.h"
import "MidiApiContracts.idl";


import "MidiBasicLoopbackCreationResponse.idl";
import "MidiBasicLoopbackRemovalResponse.idl";
import "MidiBasicLoopbackUpdateResponse.idl";

import "MidiBasicLoopbackCreationConfig.idl";
import "MidiBasicLoopbackRemovalConfig.idl";

import "MidiEndpointDeviceInformation.idl";

namespace Windows.Devices.Midi2.Transports.BasicLoopback
{
    [contract(MidiTransportsBasicLoopbackApiContract, 1)]
    
    [static_name("Windows.Devices.Midi2.Transports.BasicLoopback.IMidiBasicLoopbackManagerStatics", UUID_IMidiBasicLoopbackManagerStatics)]
    static runtimeclass MidiBasicLoopbackManager
    {
        [noexcept] static Boolean IsTransportAvailable{ get; };

        [noexcept] static Guid TransportId{ get; };

        [noexcept] static MidiBasicLoopbackCreationResponse CreateTransientLoopback(
            MidiBasicLoopbackCreationConfig creationConfig);

        [noexcept] static MidiBasicLoopbackRemovalResponse RemoveTransientLoopback(
            MidiBasicLoopbackRemovalConfig removalConfig);

        [noexcept] static Guid GetAssociationId(
            Windows.Devices.Midi2.Enumeration.MidiEndpointDeviceInformation basicLoopbackEndpoint);

        [noexcept] static Boolean DoesLoopbackExist(String uniqueIdentifier);

        [noexcept] static MidiBasicLoopbackUpdateResponse MuteLoopback(Guid associationId);
        [noexcept] static MidiBasicLoopbackUpdateResponse UnmuteLoopback(Guid associationId);

        [noexcept] static IVector<MidiBasicLoopbackEntry> GetActiveLoopbackEntries();

    }
}
