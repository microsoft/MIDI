namespace Windows.Devices.Midi2.Utilities.Messages
{
    [contract(MidiMessageUtilityApiContract,1)]
    [static_name("Windows.Devices.Midi2.Utilities.Messages.IMidiMessageConverterStatics", UUID_IMidiMessageConverterStatics)]
