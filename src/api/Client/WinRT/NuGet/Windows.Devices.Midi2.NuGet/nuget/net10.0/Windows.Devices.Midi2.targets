<Project>
  <!-- See https://aka.ms/dotnet/msbuild/customize for more details on customizing your build -->


  <Target Name="SetupMIDIServicesSDKReference"
          BeforeTargets="BeforeResolveReferences">
    <Message Text="-- Copying Windows MIDI Services references .winmd files" />


    <ItemGroup>
      <Reference Include="$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..\..\..\ref\net10.0\Windows.Devices.Midi2.winmd'))" />
    </ItemGroup>
  </Target>


