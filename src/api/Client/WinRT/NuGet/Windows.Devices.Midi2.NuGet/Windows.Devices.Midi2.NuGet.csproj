<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <BaseOutputPath>G:\Github\microsoft\midi\src\api\vsfiles-sdk\out\nuget\$(Platform)\$(Configuration)\</BaseOutputPath>
    <Platforms>AnyCPU;ARM64;x64</Platforms>
  </PropertyGroup>


  <PropertyGroup>
    <CsWinRTExcludes>
      
    </CsWinRTExcludes>
    <CsWinRTIncludes>
      Windows.Devices.Midi2
      Windows.Devices.Midi2.ClientPlugins
      Windows.Devices.Midi2.Diagnostics
      Windows.Devices.Midi2.Enumeration
      Windows.Devices.Midi2.Enumeration.Legacy
      Windows.Devices.Midi2.Reporting
      Windows.Devices.Midi2.ServiceConfig
      Windows.Devices.Midi2.Transports.BasicLoopback
      Windows.Devices.Midi2.Transports.Loopback
      Windows.Devices.Midi2.Transports.Virtual
      Windows.Devices.Midi2.Utilities.Messages
    </CsWinRTIncludes>
    <CsWinRTGeneratedFilesDir>$(OutDir)</CsWinRTGeneratedFilesDir>
    <CsWinRTGenerateProjection>False</CsWinRTGenerateProjection>
  </PropertyGroup>

  <PropertyGroup>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <GeneratedNugetDir>.\nuget\</GeneratedNugetDir>
    <NuspecFile>$(GeneratedNugetDir)Windows.Devices.Midi2.nuspec</NuspecFile>
    <PackageOutputPath>$(SolutionDir)vsfiles-sdk\PublishedNuGet\</PackageOutputPath>
  </PropertyGroup>


  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="3.0.0-preview.260319.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\t\ClientPlugins\Windows.Devices.Midi2.ClientPlugins.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\core\Windows.Devices.Midi2.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Diagnostics\Windows.Devices.Midi2.Diagnostics.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Enumeration\Windows.Devices.Midi2.Enumeration.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Reporting\Windows.Devices.Midi2.Reporting.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\ServiceConfig\Windows.Devices.Midi2.ServiceConfig.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Transports.BasicLoopback\Windows.Devices.Midi2.Transports.BasicLoopback.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Transports.Loopback\Windows.Devices.Midi2.Transports.Loopback.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Transports.Virtual\Windows.Devices.Midi2.Transports.Virtual.vcxproj">
      <Private>True</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\t\Utilities.Messages\Windows.Devices.Midi2.Utilities.Messages.vcxproj">
      <Private>True</Private>
    </ProjectReference>
  </ItemGroup>

</Project>
