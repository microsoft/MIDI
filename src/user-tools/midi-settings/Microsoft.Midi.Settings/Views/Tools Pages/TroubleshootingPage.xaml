<Page
    x:Class="Microsoft.Midi.Settings.Views.TroubleshootingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Microsoft.Midi.Settings.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:midi2="using:Microsoft.Windows.Devices.Midi2"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:Microsoft.Midi.Settings.Helpers"   
    xmlns:serviceContracts="using:Microsoft.Midi.Settings.Contracts.Services"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <helpers:BooleanToInverseVisibilityConverter x:Key="BooleanToInverseVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid  x:Name="ContentArea">
        <ScrollViewer >
            <StackPanel Orientation="Vertical" Spacing="8">

                <controls:SettingsCard x:Uid="TroubleshootingSettingsCard_SystemInformation">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC4E;" Style="{StaticResource CommonTasksIconStyles}"/>
                    </controls:SettingsCard.HeaderIcon>
                    <controls:SettingsCard.Content>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Windows Version"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="0"
                                       Grid.Row="0"/>
                            <TextBlock Text="Architecture"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="0"
                                       Grid.Row="1"/>
                            <TextBlock Text="Windows Culture Info"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="0"
                                       Grid.Row="2"/>

                            <TextBlock Text="{x:Bind ViewModel.WindowsVersion}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="1"
                                       Grid.Row="0"/>
                            <TextBlock Text="{x:Bind ViewModel.WindowsArchitecture}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="1"
                                       Grid.Row="1"/>
                            <TextBlock Text="{x:Bind ViewModel.WindowsCultureInfo}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="1"
                                       Grid.Row="2"/>


                            <TextBlock Text="Windows App SDK Version"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="2"
                                       Grid.Row="0"/>
                            <TextBlock Text=".NET Runtime Version"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="2"
                                       Grid.Row="1"/>
                            <TextBlock Text="MIDI SDK Version"
                                       Style="{StaticResource SmallPropertyLabel}"
                                       Grid.Column="2"
                                       Grid.Row="2"/>

                            <TextBlock Text="{x:Bind ViewModel.WindowsAppSdkVersion}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="3"
                                       Grid.Row="0"/>
                            <TextBlock Text="{x:Bind ViewModel.DotNetRuntimeVersion}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="3"
                                       Grid.Row="1"/>
                            <TextBlock Text="{x:Bind ViewModel.MidiSdkVersion}"
                                       Style="{StaticResource SmallEmphasizedPropertyValue}"
                                       IsTextSelectionEnabled="True"
                                       Grid.Column="3"
                                       Grid.Row="2"/>


                        </Grid>
                    </controls:SettingsCard.Content>
                </controls:SettingsCard>


                <!--<TextBlock TextWrapping="Wrap" 
                           Margin="1,0,0,8" 
                           x:Uid="TroubleshootingMainHeader"/> -->


                <!--
                <TextBlock Text="If you have a stuck note somewhere, and you're not sure where" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

