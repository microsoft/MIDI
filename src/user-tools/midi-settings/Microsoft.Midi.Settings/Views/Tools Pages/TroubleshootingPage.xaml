                <TextBlock x:Uid="TroubleshootingSection_WorkingWithSupport" 
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="TroubleshootingSettingsCard_ReportMidiSystemInfo">
                    <Button x:Uid="TroubleshootingButton_CaptureMidiSystemInfo"
                            Command="{x:Bind ViewModel.MidiDiagCommand}"/>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="TroubleshootingSettingsCard_CaptureMidiLogs">
                    <Button x:Uid="TroubleshootingButton_CaptureMidiLogs"
                            Command="{x:Bind ViewModel.CaptureMidiLogsCommand}"/>
                </controls:SettingsCard>


                <TextBlock x:Uid="TroubleshootingSection_RepairRegistry"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="TroubleshootingSettingsCard_RepairRegistry">
                    <Button x:Uid="TroubleshootingButton_RepairRegistry"
                            Command="{x:Bind ViewModel.MidiFixRegCommand}"/>
                </controls:SettingsCard>


                <!-- Registry information -->

                <Grid RowSpacing="8" ColumnSpacing="16"
                      Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="0.5*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.Resources>
                        <DataTemplate x:Key="FoundRegistryEntryTemplate" x:DataType="serviceContracts:FoundRegistryEntry">
                            <Grid Margin="2">
                                <Rectangle Fill="{StaticResource SystemControlBackgroundBaseLowBrush}" 
                                           Opacity="0.25" RadiusX="4" RadiusY="4" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="8,4,8,4">
                                    <TextBlock Width="150" Text="{x:Bind Name}" Style="{StaticResource SmallPropertyLabel}" />
                                    <TextBlock Text="{x:Bind Value}" Style="{StaticResource SmallPlainPropertyValue}" />
                                </StackPanel>
                            </Grid>
                            
                        </DataTemplate>
                    </Grid.Resources>

                    <TextBlock Grid.Column="0" 
                               Grid.Row="0"
                               Margin="4,0,16,0"
                               Text="Drivers32 Registry Values for 64 Bit Apps" 
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    
                    <ItemsControl Grid.Column="0"
                                  Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.Drivers32MidiEntries}"
                                  ItemTemplate="{StaticResource FoundRegistryEntryTemplate}">

                    </ItemsControl>

                    <TextBlock Grid.Column="1" 
                               Grid.Row="0"
                               Margin="4,0,16,0"
                               Text="Drivers32 Registry Values for 32 Bit Apps" 
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <ItemsControl Grid.Column="1"
                                  Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.Drivers32WOWMidiEntries}"
                                  ItemTemplate="{StaticResource FoundRegistryEntryTemplate}">

                    </ItemsControl>

                </Grid>
                
                
                
                
                <!--<controls:SettingsCard Header="Repair in-box service component registration"
                                   Description="If you have used developer service plugins or the developer service, and want to revert to the in-box shipped versions, click the button below."
                                       >
                    <Button Content="Restore in-box Registrations"
                            Command="{x:Bind ViewModel.RestoreInBoxComponentsCommand}"/>
                </controls:SettingsCard>-->



                <TextBlock x:Uid="TroubleshootingSection_UnknownIssue" 
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="TroubleshootingSettingsCard_RestartMidisrv">
                    <StackPanel>
                        <Button x:Uid="TroubleshootingButton_RestartMidisrv"
                                Command="{x:Bind ViewModel.RestartServiceCommand}"/>
                    </StackPanel>
                </controls:SettingsCard>



                <!--<TextBlock Text="If you've found a bug" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard Header="Report a Bug to Microsoft"
                                   Description="If you've run across something which may be a bug in Windows MIDI Services, you can report it here.">
                    <Button Content="Open Feedback Hub"/>
                </controls:SettingsCard>-->
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
