<Page
    x:Class="Microsoft.Midi.Settings.Views.ToolsScratchPadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Microsoft.Midi.Settings.Views"
    xmlns:local="using:Microsoft.Midi.Settings.ViewModels"
    xmlns:midi2="using:Microsoft.Windows.Devices.Midi2"
    xmlns:helpers="using:Microsoft.Midi.Settings.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:midicontrols="using:Microsoft.Midi.Settings.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <midicontrols:MidiEndpointAndGroupPickerControl x:Name="EndpointPicker" 
                                                    Grid.Row="0"
                                                    Margin="0, 13, 13, 0"
                                                    HorizontalAlignment="Stretch"
                                                    ShowMessageDestinationGroups="True"
                                                    ShowMessageSourceGroups="False"
                                                    SelectedEndpoint="{x:Bind ViewModel.SelectedEndpoint, Mode=TwoWay}"
                                                    SelectedGroup="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                                                    Endpoints="{x:Bind ViewModel.MidiEndpoints, Mode=OneWay}"
                                                    />

        
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Message Builders"
                       Margin="0,0,0,8"
                       Grid.Row="0" />
            
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Top">
                <Expander Header="SysEx" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" 
                                Spacing="8">
                        <Button Content="Add Empty SysEx Block"
                                  Command="{x:Bind ViewModel.AddBlankSysExBlockCommand}"/>
                        <Button Content="Add Device Identity Request"
                                  Command="{x:Bind ViewModel.AddSysExIdentityRequestCommand}"/>
                    </StackPanel>
                </Expander>

                <Expander Header="Note on/off" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <ComboBox Header="Channel" 
                                          SelectedItem="{x:Bind ViewModel.SelectedChannel, Mode=TwoWay}"
                                          ItemsSource="{x:Bind ViewModel.AllValidChannels}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="midi2:MidiChannel">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{x:Bind DisplayValue}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Header="Note" 
                                          Width="100"
                                          SelectedItem="{x:Bind ViewModel.SelectedNote, Mode=TwoWay}"
                                          ItemsSource="{x:Bind ViewModel.AllValidNotes}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="local:MidiNote">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{x:Bind NoteIndex}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="(" />
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.50"/>
                                            <TextBlock Text=")" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Header="Velocity" 
                                          SelectedItem="{x:Bind ViewModel.SelectedVelocity, Mode=TwoWay}"
                                      ItemsSource="{x:Bind ViewModel.AllValidVelocities}" />

                        <Button Content="Add Note On"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.AddNoteOnCommand}"/>
                        <Button Content="Add Note Off" 
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.AddNoteOffCommand}"/>
                    </StackPanel>
                </Expander>

                <Expander Header="Control Change" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <ComboBox Header="Channel" 
                                          SelectedItem="{x:Bind ViewModel.SelectedChannel, Mode=TwoWay}"
                                          ItemsSource="{x:Bind ViewModel.AllValidChannels}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="midi2:MidiChannel">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind DisplayValue}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Header="Controller" 
                                          Width="200"
                                          SelectedItem="{x:Bind ViewModel.SelectedController, Mode=TwoWay}"
                                          ItemsSource="{x:Bind ViewModel.AllValidControllers}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="local:MidiController">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Index}" />
                                        
                                        
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="(" Visibility="{x:Bind HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.50"/>
                                            <TextBlock Text=")" Visibility="{x:Bind HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Header="Value" 
                                  SelectedItem="{x:Bind ViewModel.SelectedControllerValue, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ViewModel.AllValidControllerValues}" />

                        <Button Content="Add CC"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.AddCCCommand}"/>
                    </StackPanel>
                </Expander>


            </StackPanel>
            
        </Grid>
        
        
        
        <Grid Grid.Row="2" 
              ColumnSpacing="16" 
              Margin="0,8,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="MIDI 1.0 Hex Bytes" Grid.Row="0" Grid.Column="0" 
                       Margin="0,8,0,8"/>

            <TextBox Grid.Column="0"
                     Grid.Row="1"
                     x:Name="HexTextBox"
                     Text="{x:Bind ViewModel.AllScratchPadText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsSpellCheckEnabled="False"
                     IsTextPredictionEnabled="False"
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     FontFamily="Consolas"
                     FontSize="16"
                     SelectionHighlightColor="{StaticResource SystemColorHighlightColor}"
                     SelectionHighlightColorWhenNotFocused="{StaticResource SystemColorHighlightColor}"
                     SelectionChanged="HexTextBox_SelectionChanged"
                     BeforeTextChanging="HexTextBox_BeforeTextChanging"/>

            <StackPanel Grid.Column="1" 
                        Grid.Row="1"
                        Orientation="Vertical"
                        Spacing="8"
                        VerticalAlignment="Center">


                <ToggleSwitch Header="Enable Running Status" 
                              IsOn="{x:Bind ViewModel.AllowRunningStatus, Mode=TwoWay}" />

                <AppBarSeparator />

                <Button Content="Send All" 
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.SendAllCommand}"
                        IsEnabled="{x:Bind ViewModel.IsSendButtonEnabled, Mode=OneWay}"/>
                
                <Button Content="Send Selected" 
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.SendSelectedCommand}"
                        IsEnabled="{x:Bind ViewModel.IsSendSelectedButtonEnabled, Mode=OneWay}"/>

            </StackPanel>
        </Grid>


        <StackPanel Grid.Row="2"
                    Spacing="16"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

        </StackPanel>


        <Grid Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Byte Count: " />
        </Grid>
        
        
    </Grid>
</Page>
