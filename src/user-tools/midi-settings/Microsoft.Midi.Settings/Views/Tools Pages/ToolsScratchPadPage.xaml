<Page
    x:Class="Microsoft.Midi.Settings.Views.ToolsScratchPadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Microsoft.Midi.Settings.Views"
    xmlns:local="using:Microsoft.Midi.Settings.ViewModels"
    xmlns:midi2="using:Microsoft.Windows.Devices.Midi2"
    xmlns:helpers="using:Microsoft.Midi.Settings.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:midicontrols="using:Microsoft.Midi.Settings.Controls"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <midicontrols:MidiEndpointAndGroupPickerControl x:Name="EndpointPicker" 
                                                    Grid.Row="0"
                                                    Margin="0, 13, 13, 0"
                                                    HorizontalAlignment="Stretch"
                                                    ShowMessageDestinationGroups="True"
                                                    ShowMessageSourceGroups="False"
                                                    SelectedEndpoint="{x:Bind ViewModel.SelectedEndpoint, Mode=TwoWay}"
                                                    SelectedGroup="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                                                    Endpoints="{x:Bind ViewModel.MidiEndpoints, Mode=OneWay}"
                                                    />

        <Grid Grid.Row="1">
            <CommandBar HorizontalAlignment="Left"
                        Margin="0,16,0,0"
                        IsOpen="True"
                        DefaultLabelPosition="Right"
                        IsDynamicOverflowEnabled="False">
                <CommandBar.PrimaryCommands>
                    <AppBarButton Label="Add Empty SysEx Block"
                                  Command="{x:Bind ViewModel.AddBlankSysExBlock}"/>
                    <AppBarButton Label="Add Device Identity Request"
                                  Command="{x:Bind ViewModel.AddSysExIdentityRequest}"/>

                    <AppBarSeparator />
                    
                    <AppBarButton Label="Load File"/>

                </CommandBar.PrimaryCommands>
            </CommandBar>

        </Grid>
        
        <Grid Grid.Row="2" 
              ColumnSpacing="16" 
              Margin="0,8,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="MIDI 1.0 Hex Bytes" Grid.Row="0" Grid.Column="0" 
                       Margin="0,8,0,8"/>

            <TextBox Grid.Column="0"
                     Grid.Row="1"
                     Text="{x:Bind ViewModel.AllScratchPadText, Mode=TwoWay}"
                     IsSpellCheckEnabled="False"
                     IsTextPredictionEnabled="False"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     FontFamily="Consolas"
                     FontSize="16"
                     BeforeTextChanging="HexTextBox_BeforeTextChanging"/>

            <StackPanel Grid.Column="1" 
                        Grid.Row="1"
                        Orientation="Vertical"
                        Spacing="8"
                        VerticalAlignment="Center">
                       

                <Button Content="Send All" />
                <Button Content="Send Selected" />

            </StackPanel>
        </Grid>


        <StackPanel Grid.Row="2"
                    Spacing="16"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

        </StackPanel>


        <Grid Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Byte Count: " />
        </Grid>
        
        
    </Grid>
</Page>
