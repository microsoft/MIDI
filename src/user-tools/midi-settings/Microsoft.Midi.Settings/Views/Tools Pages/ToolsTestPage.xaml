<Page
    x:Class="Microsoft.Midi.Settings.Views.ToolsTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Microsoft.Midi.Settings.Views"
    xmlns:local="using:Microsoft.Midi.Settings.ViewModels"
    xmlns:midi2="using:Microsoft.Windows.Devices.Midi2"
    xmlns:helpers="using:Microsoft.Midi.Settings.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:midicontrols="using:Microsoft.Midi.Settings.Controls"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <midicontrols:MidiEndpointAndGroupPickerControl x:Name="EndpointPicker" 
                                                    Grid.Row="0"
                                                    Margin="0, 13, 13, 0"
                                                    HorizontalAlignment="Stretch"
                                                    ShowMessageDestinationGroups="True"
                                                    ShowMessageSourceGroups="False"
                                                    SelectedEndpoint="{x:Bind ViewModel.SelectedEndpoint, Mode=TwoWay}"
                                                    SelectedGroup="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                                                    Endpoints="{x:Bind ViewModel.MidiEndpoints, Mode=OneWay}"
                                                    />


        <TabView Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TabView.TabItems>
                <TabViewItem Header="Common Messages" IsClosable="False">
                    <StackPanel Orientation="Vertical" 
                                Spacing="8">
                        <Button Content="Send SysEx Device Id Request" />
                    </StackPanel>
                </TabViewItem>

                <TabViewItem Header="MIDI 2.0 Messages" IsClosable="False">
                    <StackPanel Orientation="Vertical" 
                                Spacing="8">
                        <Button Content="Send Discovery Identity Request" />
                    </StackPanel>
                </TabViewItem>

                <TabViewItem Header="Scratch Pad" IsClosable="False">
                    <!-- Selection for MIDI 1 or MIDI 2 messages (save to settings) -->

                    <Grid ColumnSpacing="16" Margin="0,0,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        
                        <TextBox Grid.Column="0"
                                 IsSpellCheckEnabled="False"
                                 IsTextPredictionEnabled="False"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 FontFamily="Consolas"
                                 FontSize="16"
                                 BeforeTextChanging="HexTextBox_BeforeTextChanging"/>

                        <StackPanel Grid.Column="1" 
                                    Orientation="Vertical"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                        
                            <Button Content="Send" />
                            <Button Content="Clear" />
                            
                            <!-- TODO: Open file -->

                        </StackPanel>
                    </Grid>

                </TabViewItem>
            </TabView.TabItems>
        </TabView>
        


        <!-- selection "tabs" for what we're sending -->

        
        
        
        <!-- Send SysEx Identity Request -->
        

        <!-- Text box for pasting in messages -->
        
        
        
        
        
    </Grid>
</Page>
