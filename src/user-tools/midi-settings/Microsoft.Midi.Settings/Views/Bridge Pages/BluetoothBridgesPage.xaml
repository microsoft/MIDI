<Page
    x:Class="Microsoft.Midi.Settings.Views.BluetoothBridgesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Microsoft.Midi.Settings.Views"
    xmlns:local="using:Microsoft.Midi.Settings.ViewModels"
    xmlns:midi2="using:Microsoft.Windows.Devices.Midi2"
    xmlns:helpers="using:Microsoft.Midi.Settings.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:midicontrols="using:Microsoft.Midi.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    >

    <Grid x:Name="ContentArea">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal"
                    Grid.Row="0">

            <Button x:Name="CreateNewBridge" 
                    Visibility="{x:Bind ViewModel.IsConfigFileActive, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="5,13,13,13"
                    Content="Create New Bluetooth Bridge"
                    Click="CreateNewBridge_Click"
                            />
        </StackPanel>

        <!-- TODO: List of existing bridges -->
        
        
        <!-- TODO: Move to a dialog -->

        
        
        <ContentDialog x:Name="Dialog_CreateBridge"
                       PrimaryButtonText="OK" 
                       IsPrimaryButtonEnabled="{x:Bind ViewModel.NewBridgeSettingsAreValid, Mode=OneWay}"
                       CloseButtonText="Cancel"
                       PrimaryButtonCommand="{x:Bind ViewModel.CreateNewBridgeCommand}"
                       >
            <ContentDialog.Resources>
                <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
                <x:Double x:Key="ContentDialogMaxHeight">850</x:Double>
            </ContentDialog.Resources>

            <Grid Margin="-24">
                <TextBlock Text="No WinRT MIDI 1.0 Bluetooth ports found"
                           Visibility="{x:Bind ViewModel.BleMidi1PortsFound, Converter={StaticResource BooleanToInverseVisibilityConverter}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              Visibility="{x:Bind ViewModel.BleMidi1PortsFound, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" 
                                    Grid.RowSpan="1" 
                                    Background="{ThemeResource AccentFillColorSelectedTextBackgroundBrush}"
                                    Opacity="0.1"
                                    HorizontalAlignment="Stretch" />


                        <Grid Grid.Row="0" Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                       Text="Create New Bluetooth Bridge" Style="{StaticResource DialogHeaderTextBlockStyle}" />

                            <TextBlock Grid.Row="1" 
                                       Margin="0,24,0,8" 
                                       Style="{StaticResource DialogDescriptionTextBlockStyle}" 
                                       Text="While we work on the official BLE MIDI 1.0 and BLE MIDI 2.0 transports, the Bluetooth bridge is a temporary way to make Bluetooth MIDI devices available to WinMM MIDI and through the Windows MIDI Services App SDK. Your MIDI 1.0 and MIDI 2.0 apps will be able to access currently supported and recognized BLE MIDI 1.0 devices through this bridge." />
                        </Grid>


                        <StackPanel Orientation="Vertical" 
                                Grid.Row="1"
                                    Margin="24"
                            Spacing="8" 
                            HorizontalAlignment="Stretch">
                            <TextBlock Margin="0,8,0,16" 
                               Style="{StaticResource DialogDescriptionTextBlockStyle}" 
                               Text="These are the two Bluetooth MIDI 1.0 ports which will be bridged to the new endpoint. Normally, these are both from the same BLE MIDI 1.0 device." />

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                      ItemsSource="{x:Bind ViewModel.SourcePorts, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSourcePort, Mode=TwoWay}"
                                      Header="BLE MIDI Input (Source) Port"
                                      Width="350">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.DestinationPorts, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedDestinationPort, Mode=TwoWay}"
                                      Header="BLE MIDI Output (Destination) Port"
                                      Width="350">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <TextBlock Margin="0,24,0,16" 
                               Style="{StaticResource DialogDescriptionTextBlockStyle}" 
                               Text="Please provide a name for your new endpoint. This is the name for the input and output port in MIDI 1.0, and the endpoint itself through the new SDK." />

                            <TextBox Header="Bridge Endpoint Name"
                                 Margin="0,0,0,32"
                                 HorizontalAlignment="Left"
                                 IsSpellCheckEnabled="False"
                                 MaxLength="31"
                                 Width="350"/>

                        </StackPanel>


                    </Grid>
                    
                    
                </ScrollViewer>

            </Grid>
            
        </ContentDialog>

    </Grid>

</Page>
